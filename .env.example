# ── App ──────────────────────────────────────────
APP_NAME=agentic-rag
APP_ENV=dev
DEBUG=true

# ── LLM gateway (Phase 1) ────────────────────────
# All chat + embedding traffic routed through OpenRouter (single key).
# Model IDs are slash-prefixed: openai/gpt-4o, openai/text-embedding-3-large,
# google/gemini-2.5-flash, etc. Override per-node via the LLM_* vars below.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=agentic-rag

LLM_MODEL_CLASSIFY=google/gemini-2.5-flash
LLM_MODEL_DECOMPOSE=google/gemini-2.5-flash
LLM_MODEL_ASSESS=google/gemini-2.5-flash
LLM_MODEL_REFORMULATE=google/gemini-2.5-flash
LLM_MODEL_GENERATE=openai/gpt-4o
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMS=1536

# ── Auth (Logto OSS, self-hosted via docker-compose) ───────
# Local dev: leave LOGTO_ENDPOINT pointing at the local Docker container.
# Production (Dokploy): set LOGTO_ENDPOINT/ADMIN_ENDPOINT to the public URLs
# behind your reverse proxy AND set LOGTO_SECRET_VAULT_KEK once with
# `openssl rand -base64 32` so encrypted secrets survive container restarts.
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ADMIN_ENDPOINT=http://localhost:3002
# Optional: service-to-service URL for JWKS fetch. Set to http://logto:3001
# when api/worker run inside docker-compose; leave empty for host-mode dev.
LOGTO_INTERNAL_ENDPOINT=
LOGTO_RESOURCE=https://api.agentic-rag
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# Pin this in production. Leave blank locally — Logto auto-generates one.
LOGTO_SECRET_VAULT_KEK=

# ── PostgreSQL ───────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_HOST=postgres                # service name inside Docker network
POSTGRES_PORT=5432                    # in-container port (used by api/worker)
# Host-side port mapping. Set to 5433 (or anything free) on machines that
# already run a system PostgreSQL on 5432. On Dokploy / cloud servers this
# usually doesn't matter — leave default.
POSTGRES_HOST_PORT=5433

# ── Redis (triple-role) ──────────────────────────
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
SEMANTIC_CACHE_REDIS_URL=redis://redis:6379/2
CACHE_SIMILARITY_THRESHOLD=0.88
CACHE_TTL_SECONDS=86400

# ── Qdrant ───────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Agent tuning ─────────────────────────────────
CONTEXT_SCORE_THRESHOLD=7
MAX_RETRIEVAL_ITERATIONS=3

# ── Langfuse (Phase 2) ───────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
